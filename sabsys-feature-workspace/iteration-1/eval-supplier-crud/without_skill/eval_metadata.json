{
  "eval_id": 1,
  "eval_name": "eval-supplier-crud",
  "prompt": "Add a Supplier model to sabsys with full stack: model, form, filter, views (list with datatable, detail, create inline, edit via HTMX modal, delete with guard), URLs, templates, admin, factory, and view tests.",
  "assertions": [
    {"text": "model_inherits_ERPBaseModel", "passed": true, "evidence": "class Supplier(ERPBaseModel) with correct import"},
    {"text": "model_has_organization_fk", "passed": true, "evidence": "organization FK to accounts.Organization present with CASCADE"},
    {"text": "model_has_status_textchoices", "passed": true, "evidence": "class Status(models.TextChoices) inner class"},
    {"text": "views_use_ERPBaseViewMixin", "passed": true, "evidence": "All views inherit ERPBaseViewMixin"},
    {"text": "list_view_uses_DataTableMixin", "passed": true, "evidence": "SupplierListView(ERPBaseViewMixin, DataTableMixin, TemplateView) with all dt_ attrs"},
    {"text": "list_view_scopes_to_org", "passed": true, "evidence": "Supplier.objects.for_org(_org(request)) used consistently"},
    {"text": "delete_view_is_post_only", "passed": true, "evidence": "SupplierDeleteView only defines post()"},
    {"text": "delete_view_admin_required", "passed": true, "evidence": "admin_required = True on delete view"},
    {"text": "htmx_refresh_table_classmethod", "passed": true, "evidence": "@classmethod refresh_table with HX-Trigger showToast"},
    {"text": "plain_view_uses_self_get_context", "passed": true, "evidence": "SupplierDetailView.get() uses self.get_context(...)"},
    {"text": "urls_use_uuid_pk", "passed": true, "evidence": "<uuid:pk> in all pk routes"},
    {"text": "factory_mutes_signals", "passed": true, "evidence": "@mute_signals(post_save) on SupplierFactory"},
    {"text": "test_login_sets_session", "passed": true, "evidence": "Separate login() + set_active_org() utilities both call force_login and set session['active_org_slug'] — pattern is met though split into two helpers"},
    {"text": "templates_in_spanish", "passed": true, "evidence": "Agent output confirms Spanish button labels and verbose names throughout templates"},
    {"text": "form_tag_false", "passed": true, "evidence": "self.helper.form_tag = False in SupplierForm.__init__"}
  ]
}
