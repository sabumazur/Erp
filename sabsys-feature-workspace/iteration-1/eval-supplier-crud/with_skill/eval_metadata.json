    {"text": "model_has_organization_fk", "passed": true, "evidence": "organization = models.ForeignKey('accounts.Organization', on_delete=models.CASCADE, related_name='suppliers')"},
    {"text": "model_has_status_textchoices", "passed": true, "evidence": "class Status(models.TextChoices): ACTIVE / INACTIVE inner class on Supplier model"},
    {"text": "views_use_ERPBaseViewMixin", "passed": true, "evidence": "All 4 views inherit ERPBaseViewMixin from apps.accounts.views"},
    {"text": "list_view_uses_DataTableMixin", "passed": true, "evidence": "SupplierListView(ERPBaseViewMixin, DataTableMixin, TemplateView) with dt_columns, dt_url, dt_row_template, dt_id defined"},
    {"text": "list_view_scopes_to_org", "passed": true, "evidence": "Supplier.objects.for_org(request.organization) used in refresh_table and get_context_data"},
    {"text": "delete_view_is_post_only", "passed": true, "evidence": "SupplierDeleteView only defines post() method"},
    {"text": "delete_view_admin_required", "passed": true, "evidence": "admin_required = True on SupplierDeleteView"},
    {"text": "htmx_refresh_table_classmethod", "passed": true, "evidence": "@classmethod refresh_table returns HX-Trigger showToast JSON"},
    {"text": "plain_view_uses_self_get_context", "passed": true, "evidence": "SupplierDetailView.get() calls self.get_context(supplier=..., breadcrumbs=...)"},
    {"text": "urls_use_uuid_pk", "passed": true, "evidence": "path('<uuid:pk>/'), path('<uuid:pk>/editar/'), path('<uuid:pk>/eliminar/') in urls.py"},
    {"text": "factory_mutes_signals", "passed": true, "evidence": "@mute_signals(post_save) on SupplierFactory"},
    {"text": "test_login_sets_session", "passed": true, "evidence": "_login() method calls force_login AND sets session['active_org_slug']"},
    {"text": "templates_in_spanish", "passed": true, "evidence": "Agent report confirms Spanish labels; Guardar/Cancelar/Eliminar in modal form template"},
    {"text": "form_tag_false", "passed": true, "evidence": "self.helper.form_tag = False in SupplierForm.__init__"}
  ]
}
